<Page x:Class="Dartsmanager.Views.Pages.PlayerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Dartsmanager.Views.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PlayerPage">

    <Grid Margin="5" >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="125"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Button Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Left" x:Name="BT_PlayerOverview"
                Content="Terug naar overzicht" Click="BT_PlayerOverview_Click" Style="{StaticResource Button_B1}" />
        
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Overzicht speler" Style="{StaticResource TextBlock_H2}" />
        <Button Grid.Row="1" Grid.Column="1" x:Name="BT_Update_Speler" Content="Update speler" Click="BT_Update_Speler_Click" Style="{StaticResource Button_B3}"/>
        
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Voornaam" Style="{StaticResource TextBlock_H3}" Margin="5,5,5,0"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="TB_Voornaam" Style="{StaticResource TextBox_Info}"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Naam" Style="{StaticResource TextBlock_H3}" Margin="5,5,5,0"/>
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="TB_Naam" Style="{StaticResource TextBox_Info}"/>
        
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Lid sinds" Style="{StaticResource TextBlock_H3}" Margin="5,5,5,0"/>
        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="TB_LidSinds" Style="{StaticResource TextBlock_p}"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Ranking" Style="{StaticResource TextBlock_H3}" Margin="5,5,5,0"/>
        <TextBlock Grid.Row="5" Grid.Column="1" x:Name="TB_Ranking" Style="{StaticResource TextBlock_p}"/>        

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Geboortedatum" Style="{StaticResource TextBlock_H3}" Margin="5,5,5,0"/>
        <TextBox Grid.Row="6" Grid.Column="1" x:Name="TB_Geboortedatum" Style="{StaticResource TextBox_Info}"/>

        <TextBlock Grid.Row="7" Grid.Column="0" Text="Mail" Style="{StaticResource TextBlock_H3}" Margin="5,5,5,0"/>
        <TextBox Grid.Row="7" Grid.Column="1" x:Name="TB_Mail" Style="{StaticResource TextBox_Info}"/>

        <TextBlock Grid.Row="8" Grid.Column="0" Text="Telefoonnummer" Style="{StaticResource TextBlock_H3}" Margin="5,5,5,0"/>
        <TextBox Grid.Row="8" Grid.Column="1" x:Name="TB_Telefoonnummer" Style="{StaticResource TextBox_Info}"/>        

        <TextBlock Grid.Row="9" Grid.Column="0" Text="Adres" Style="{StaticResource TextBlock_H3}" Margin="5,5,5,0"/>
        <ComboBox Grid.Row="9" Grid.Column="1" x:Name="CB_Adresses" Style="{StaticResource ComboBox_C1}" DisplayMemberPath="AdresVolledig" SelectedValuePath="Id"/>
        <Button Grid.Row="9" Grid.Column="2" x:Name="BT_Create_Adress" Content="Creëer" Click="BT_Create_Adress_Click" Style="{StaticResource Button_B3}" Margin="5,5,5,0"/>
    </Grid>

</Page>