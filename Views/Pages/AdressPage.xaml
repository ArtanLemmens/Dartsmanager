<Page x:Class="Dartsmanager.Views.Pages.AdressPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Dartsmanager.Views.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AdressPage">


    <Grid Margin="5" >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Button Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Left" x:Name="BT_AdressOverview"
                Content="Terug naar overzicht" Click="BT_AdressOverview_Click" Style="{StaticResource Button_B1}" />

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Overzicht adres" Style="{StaticResource TextBlock_H2}" />
        <Button Grid.Row="1" Grid.Column="1" x:Name="BT_Update_Adress" Content="Update adres" Click="BT_Update_Adress_Click" Style="{StaticResource Button_B3}"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Straat" Style="{StaticResource TextBlock_H3}" Margin="5,5,5,0"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="TB_Straat" Style="{StaticResource TextBox_Info}"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Huisnummer/toevoeging" Style="{StaticResource TextBlock_H3}" Margin="5,5,5,0"/>
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="TB_Huisnummer" Style="{StaticResource TextBox_Info}"/>
        <TextBox Grid.Row="3" Grid.Column="2" x:Name="TB_Toevoeging" Style="{StaticResource TextBox_Info}"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Gemeente/Postcode" Style="{StaticResource TextBlock_H3}" Margin="5,5,5,0"/>
        <TextBox Grid.Row="4" Grid.Column="1" x:Name="TB_Gemeente" Style="{StaticResource TextBox_Info}"/>
        <TextBox Grid.Row="4" Grid.Column="2" x:Name="TB_Postcode" Style="{StaticResource TextBox_Info}"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Land" Style="{StaticResource TextBlock_H3}" Margin="5,5,5,0"/>
        <ComboBox Grid.Row="5" Grid.Column="1"  x:Name="CB_Landen" Style="{StaticResource ComboBox_C1}" DisplayMemberPath="Naam" SelectedValuePath="Id"/>
        <Button Grid.Row="5" Grid.Column="2" x:Name="BT_Create_Country" Content="Creëer" Click="BT_Create_Country_Click" Style="{StaticResource Button_B3}" Margin="5,5,5,0"/>
    </Grid>

</Page>