<Page x:Class="Dartsmanager.Views.Pages.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Dartsmanager.Views.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AdminPage">
    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ADMINMENU -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Height="50">
            <Button x:Name="BT_Users" Content="Gebruikers" Click="BT_Users_Click" Style="{StaticResource Button_B1}" />
            <Button x:Name="BT_Players" Content="Spelers" Click="BT_Players_Click" Style="{StaticResource Button_B1}" />
            <Button x:Name="BT_Tournaments" Content="Tornooien" Click="BT_Tournaments_Click" Style="{StaticResource Button_B1}" />            
        </StackPanel>

        <!-- ADMINPAGE -->
        <Frame x:Name="Frame_Admin"  Grid.Row="1"  NavigationUIVisibility="Hidden"/>
    </Grid>

</Page>