<Page x:Class="Dartsmanager.Views.Pages.AdressOverview"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Dartsmanager.Views.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AdressOverview">

    <Page.Resources>
        <DataTemplate x:Key="Template_Adressen">
            <Grid Margin="0" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="400"/>
                </Grid.ColumnDefinitions>
                <TextBlock Style="{StaticResource TextBlock_LB}" Text="{Binding AdresVolledig}" Grid.Column="0"/>
            </Grid>
        </DataTemplate>
    </Page.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- TITEL -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Adressen" Style="{StaticResource TextBlock_H2}" />

        <!-- ZOEKBOX -->
        <Border Grid.Row="1" Grid.Column="0" CornerRadius="10" BorderBrush="Black" BorderThickness="1" Background="#2B2B2B" Margin="5" MinWidth="200" >
            <TextBox x:Name="TB_Adres" Style="{StaticResource TextBox_Search}" Text="Zoek adres..." GotFocus="TB_Adres_GotFocus" LostFocus="TB_Adres_LostFocus" TextChanged="TB_Adres_TextChanged"/>
        </Border>
        <Button Grid.Row="1" Grid.Column="1" x:Name="BT_Create_Adress" Content="Nieuwe adres" Click="BT_Create_Adress_Click" Style="{StaticResource Button_B3}"/>
        <Button Grid.Row="1" Grid.Column="2" x:Name="BT_View_Adress" Content="Bekijk adres" Click="BT_View_Adress_Click" Style="{StaticResource Button_B3}" Foreground="Orange"/>
        <Button Grid.Row="1" Grid.Column="3" x:Name="BT_Remove_Adress" Content="Verwijder adres" Click="BT_Remove_Adress_Click" Style="{StaticResource Button_B3}" 
                Foreground="Red" HorizontalAlignment="Left"/>

        <!-- HEADER -->
        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4"  BorderBrush="Black" BorderThickness="0,0,0,1" Background="#2B2B2B" Margin="5,5,5,0" HorizontalAlignment="Left">
            <Grid  Margin="5,5,7,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="400"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Adres" Style="{StaticResource TextBlock_LB_Titel}" Grid.Column="0"/>
            </Grid>
        </Border>


        <!-- LISTBOX -->
        <ListBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4" x:Name="LB_Adressen"  
                 BorderBrush="DarkGray" Style="{StaticResource ListBox_L1}" ItemTemplate="{StaticResource Template_Adressen}" d:ItemsSource="{d:SampleData ItemCount=2}"/>


    </Grid>
</Page>
