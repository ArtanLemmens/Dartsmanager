<Window x:Class="Dartsmanager.Views.Windows.AdressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Dartsmanager.Views.Windows"
        mc:Ignorable="d"
        Title="AdresScherm" Height="600" Width="300" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto "/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Text="Nieuw adres" Style="{StaticResource TextBlock_H1}" HorizontalAlignment="Center"/>

        <TextBlock Grid.Row="1" Text="Straat" Style="{StaticResource TextBlock_H3}" Margin="5,5,5,0"/>
        <TextBox Grid.Row="2" x:Name="TB_Straat" Style="{StaticResource TextBox_Info}" />

        <TextBlock Grid.Row="3" Text="Huisnummer" Style="{StaticResource TextBlock_H3}" Margin="5,5,5,0"/>
        <TextBox Grid.Row="4" x:Name="TB_Huisnummer" Style="{StaticResource TextBox_Info}" />

        <TextBlock Grid.Row="5" Text="Toevoeging" Style="{StaticResource TextBlock_H3}" Margin="5,5,5,0"/>
        <TextBox Grid.Row="6" x:Name="TB_Toevoeging" Style="{StaticResource TextBox_Info}" />

        <TextBlock Grid.Row="7" Text="Postcode" Style="{StaticResource TextBlock_H3}" Margin="5,5,5,0"/>
        <TextBox Grid.Row="8" x:Name="TB_Postcode" Style="{StaticResource TextBox_Info}" />

        <TextBlock Grid.Row="9" Text="Gemeente" Style="{StaticResource TextBlock_H3}" Margin="5,5,5,0"/>
        <TextBox Grid.Row="10" x:Name="TB_Gemeente" Style="{StaticResource TextBox_Info}" />

        <StackPanel Grid.Row="11" Orientation="Horizontal" HorizontalAlignment="Left">
            <TextBlock Grid.Row="11"  Text="Land" Style="{StaticResource TextBlock_H3}" Margin="5,5,5,0" />
            <Button x:Name="BT_Create_Land" Content="Creëer" Click="BT_Create_Land_Click" Style="{StaticResource Button_B3}" Margin="5,5,5,0"/>
        </StackPanel>

        <ComboBox Grid.Row="12" x:Name="CB_Landen" Style="{StaticResource ComboBox_C1}" DisplayMemberPath="Naam" SelectedValuePath="Id"/>

        <Button Grid.Row="13" x:Name="BT_Create" Content="Creëer" Click="BT_Create_Click" 
            Style="{StaticResource Button_B2}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="5,20,5,5"/>

        <Button Grid.Row="14" x:Name="BT_Cancel" Content="Cancel" Click="BT_Cancel_Click" 
            Style="{StaticResource Button_B3}" Foreground="Red"/>

    </Grid>
</Window>
