<Window x:Class="Dartsmanager.Views.Windows.UserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Dartsmanager.Views.Windows"
        mc:Ignorable="d"
        Title="Registreer" Height="420" Width="300" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto "/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="35"/>
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Text="Registreer" Style="{StaticResource TextBlock_H1}" HorizontalAlignment="Center"/>
        <TextBlock Grid.Row="1" Text="Username" Style="{StaticResource TextBlock_H3}" Margin="5,5,5,0"/>
        <TextBox Grid.Row="2" x:Name="TB_Username" Style="{StaticResource TextBox_Info}" />
        <TextBlock Grid.Row="3"  Text="Wachtwoord" Style="{StaticResource TextBlock_H3}" Margin="5,5,5,0"/>
        <PasswordBox Grid.Row="4" x:Name="TB_Wachtwoord" Style="{StaticResource PasswordBox_P1}" />
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Left">
            <TextBlock Grid.Row="5"  Text="Speler" Style="{StaticResource TextBlock_H3}" Margin="5,5,5,0" />
            <Button x:Name="BT_Create_Player" Content="Creëer" Click="BT_Create_Player_Click" Style="{StaticResource Button_B3}" Margin="5,5,5,0"/>
        </StackPanel>
        
        <ComboBox Grid.Row="6" x:Name="CB_Spelers" 
                  Style="{StaticResource ComboBox_C1}"  ItemsSource="{Binding Spelers}"
                  DisplayMemberPath="VoornaamNaam" SelectedValuePath="Id"/>

        <Button Grid.Row="7" x:Name="BT_Create" Content="Creëer" Click="BT_Create_Click" 
            Style="{StaticResource Button_B2}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="5,20,5,5"/>
        <Button Grid.Row="8" x:Name="BT_Cancel" Content="Cancel" Click="BT_Cancel_Click" 
        Style="{StaticResource Button_B3}" Foreground="Red"/>
        
    </Grid>
</Window>

